# ----------------------------------------------------------------------------
# CruceEP environment variables
#
# Copy this file to `.env.local` and fill in values as needed.
# The app is designed to RUN WITHOUT any of these set: when Supabase or map
# keys are absent it falls back to mock providers and browser-local storage.
# ----------------------------------------------------------------------------

# --- App environment -------------------------------------------------------
# Controls how clearly "mock" data is labeled. One of: development | demo | production
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Absolute site origin, used for canonical URLs (robots, sitemap, auth
# redirects). On Vercel this is auto-derived; set explicitly for a custom domain.
NEXT_PUBLIC_SITE_URL=

# --- Supabase --------------------------------------------------------------
# Get these from your Supabase project: Settings -> API.
# Leave blank to run the app fully on mock data + localStorage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose this to the browser. Used by admin/server routes.
SUPABASE_SERVICE_ROLE_KEY=

# --- Maps ------------------------------------------------------------------
# Provider abstraction. One of: leaflet | mapbox | google
# `leaflet` requires no API key (OpenStreetMap tiles) and is the safe default.
NEXT_PUBLIC_MAP_PROVIDER=leaflet
# Only needed if NEXT_PUBLIC_MAP_PROVIDER=mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
# Only needed if NEXT_PUBLIC_MAP_PROVIDER=google
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Data providers --------------------------------------------------------
# Each selects which adapter implementation is used. `mock` works offline.
# border wait: mock | cbp   (cbp not yet implemented; documented in README)
BORDER_WAIT_PROVIDER=mock
# transit: mock | sunmetro-gtfs | eta-gtfs
TRANSIT_PROVIDER=mock
# weather: mock | nws  (set to `nws` in production for LIVE National Weather
# Service data; falls back to mock automatically if the API is unreachable)
WEATHER_PROVIDER=mock
# alerts: mock | composite
ALERT_PROVIDER=mock

# --- NWS weather (only used when WEATHER_PROVIDER=nws) ----------------------
# El Paso station id for the latest observation (default KELP = El Paso Intl).
NWS_STATION_ID=KELP
# NWS API policy requires a self-identifying User-Agent (add a contact URL/email).
NWS_USER_AGENT=CruceEP/1.0 (https://github.com/Juan-R1/Juan-R1)
